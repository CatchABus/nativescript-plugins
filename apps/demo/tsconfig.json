{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "@nativescript-community/ui-jsx",
		"rootDirs": [".", "../.."],
		"baseUrl": ".",
		"lib": ["esnext", "dom"],
		"paths": {
			"~/*": ["src/*"],
			"@demo/shared": ["../../tools/demo/index.ts"],
			"@nativescript-community/*": ["../../packages/*"],
			"@nativescript-community/ui-jsx": ["../../packages/ui-jsx/index.d.ts"],
			"@nativescript-community/ui-neumorphiclayout": ["../../packages/ui-neumorphiclayout/index.d.ts"],
			"@nativescript-community/dns-lookup": ["../../packages/dns-lookup/index.d.ts"],
			"@nativescript-community/nordic-dfu": ["../../packages/nordic-dfu/index.d.ts"],
			"@nativescript-community/ui-constraintlayout": ["../../packages/ui-constraintlayout/index.d.ts"],
			"@nativescript-community/ui-htmlcanvasapi": ["../../packages/ui-htmlcanvasapi/index.d.ts"],
			"@nativescript-community/ui-maplibre": ["../../packages/ui-maplibre/index.d.ts"]
		}
	}
}
